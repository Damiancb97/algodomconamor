# Copiar este archivo a .env y rellenar los valores

# ── Sanity (mismo valor que web/.env.local) ───────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=wfz6uel0
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-24

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Obtener en: Zero Trust → Networks → Tunnels → <tu tunnel> → Configure → token
CLOUDFLARE_TUNNEL_TOKEN=
